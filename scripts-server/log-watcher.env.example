# Usurper Reborn - Log Watcher environment file
#
# Install path on the server: /etc/usurper/log-watcher.env
# Owner/mode: root:usurper 0640 (readable by the service user, not by other users).
#
# DO NOT commit the populated file. This example lives in the repo so anyone
# deploying their own server knows what the log watcher expects; the real
# values belong only on the deployed host.
#
# Rotate the webhook in Discord server settings > Integrations > Webhooks
# if this URL ever leaks, then update this file and run:
#   sudo systemctl restart usurper-log-watcher

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME
